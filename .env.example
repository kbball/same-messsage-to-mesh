# Copy this file to .env for local development. Never commit .env.

# Application
SERVER_PORT=8080
LOG_LEVEL=info

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=same_mesh
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL_MODE=disable

# SDR (configurable via UI; these are fallback defaults at first boot)
SDR_DEVICE_PATH=/dev/bus/usb
# NOAA Weather Radio frequencies (Hz):
#   162400000  162425000  162450000  162475000
#   162500000  162525000  162550000 (default - most common)
SDR_FREQUENCY=162550000

# MQTT (publishing decoded alerts to mesh)
# Set MQTT_ENABLED=true to publish alerts to the Mosquitto broker
MQTT_ENABLED=false
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_PUBLISH_TOPIC=same/alerts

# MeshCore bridge (optional — consumed by the meshcore-mqtt sidecar, not the app)
# Run with: docker compose --profile meshcore up
# MESHCORE_ADDRESS is the IP of your MeshCore node (TCP connection)
MESHCORE_ADDRESS=192.168.1.50
MESHCORE_PORT=5000
MESHCORE_CHANNEL_INDEX=0
